# Copy this file to .env and fill in your own values.
# .env is gitignored - it will never be committed.

# Monad testnet JSON-RPC endpoint (from https://docs.monad.xyz/developer-essentials/testnets)
MONAD_TESTNET_RPC_URL=https://testnet-rpc.monad.xyz

# Deployer wallet private key, starting with 0x.
# This wallet needs testnet MON - fund it at https://faucet.monad.xyz
# NEVER share this key or commit it anywhere.
PRIVATE_KEY=

# Only needed if you verify via Monadscan (Etherscan-style) instead of Sourcify/MonadVision.
# Get a key at https://monadscan.com - leave blank if you're using Sourcify verification.
MONADSCAN_API_KEY=
